{
  "env": {
    "MCP_TIMEOUT": "30000"
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "mcp__wifi-cam__see|mcp__usb-webcam__see",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/run-see-embed.cmd",
            "timeout": 35
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/run-interoception.cmd",
            "timeout": 15
          },
          {
            "type": "command",
            "command": ".claude/hooks/run-keyword-buffer.cmd",
            "timeout": 15
          },
          {
            "type": "command",
            "command": ".claude/hooks/run-recall-lite.cmd",
            "timeout": 15
          },
          {
            "type": "command",
            "command": ".claude/hooks/run-passive-vision.cmd",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
