{
  "env": {
    "MCP_TIMEOUT": "30000"
  },
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/run-interoception.cmd",
            "timeout": 15
          },
          {
            "type": "command",
            "command": ".claude/hooks/run-keyword-buffer.cmd",
            "timeout": 15
          },
          {
            "type": "command",
            "command": ".claude/hooks/run-recall-lite.cmd",
            "timeout": 15
          }
        ]
      }
    ]
  }
}
