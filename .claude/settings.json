{
  "env": {
    "MCP_TIMEOUT": "30000"
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "compact",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/post-compact-recovery.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/interoception.sh",
            "timeout": 15
          },
          {
            "type": "command",
            "command": ".claude/hooks/run-keyword-buffer.sh",
            "timeout": 15
          },
          {
            "type": "command",
            "command": ".claude/hooks/run-recall-lite.sh",
            "timeout": 15
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/continue-check.sh",
            "timeout": 10
          }
        ]
      }
    ]
  }
}