# Memory MCP Server Configuration

# Path to SQLite database (default: ~/.claude/memories/memory.db)
# MEMORY_DB_PATH=/home/user/.claude/memories/memory.db

# Path to chiVe Word2Vec model file (REQUIRED)
# Download from: https://github.com/WorksApplications/chiVe
# CHIVE_MODEL_PATH=/path/to/chive-1.3-mc5_gensim/chive-1.3-mc5.kv

# Enable BM25 keyword search (default: true)
# MEMORY_ENABLE_BM25=true

# Path to MEMORY.md for auto-compaction (optional)
# MEMORY_MD_PATH=/path/to/MEMORY.md
